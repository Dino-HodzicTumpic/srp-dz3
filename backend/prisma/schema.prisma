generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model parkings {
  id            Int             @id @default(autoincrement())
  zone_id       Int
  name          String          @db.VarChar(100)
  location      String          @db.VarChar(255)
  total_spaces  Int             @default(0)
  created_at    DateTime        @default(now()) @db.Timestamp(6)
  parkingzones  parkingzones    @relation(fields: [zone_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parkingspaces parkingspaces[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model parkingspaces {
  id           Int            @id @default(autoincrement())
  parking_id   Int
  space_number String         @db.VarChar(10)
  space_type   String         @default("standard") @db.VarChar(15)
  parkings     parkings       @relation(fields: [parking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reservations reservations[]

  @@unique([parking_id, space_number])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model parkingzones {
  id             Int        @id @default(autoincrement())
  name           String     @unique @db.VarChar(10)
  price_per_hour Decimal    @db.Decimal(6, 2)
  description    String?    @db.VarChar(255)
  parkings       parkings[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payments {
  id             Int          @id @default(autoincrement())
  reservation_id Int          @unique
  amount         Decimal      @db.Decimal(8, 2)
  status         String       @default("pending") @db.VarChar(10)
  payment_method String?      @default("card") @db.VarChar(20)
  paid_at        DateTime?    @db.Timestamp(6)
  reservations   reservations @relation(fields: [reservation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reservations {
  id               Int           @id @default(autoincrement())
  user_id          Int
  vehicle_id       Int
  parking_space_id Int
  start_time       DateTime      @db.Timestamp(6)
  end_time         DateTime      @db.Timestamp(6)
  status           String        @default("active") @db.VarChar(12)
  created_at       DateTime      @default(now()) @db.Timestamp(6)
  payments         payments?
  parkingspaces    parkingspaces @relation(fields: [parking_space_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicles         vehicles      @relation(fields: [vehicle_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([parking_space_id, start_time, end_time], map: "idx_reservations_space_time", where: raw("((status)::text = 'active'::text)"))
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(100)
  email         String         @unique @db.VarChar(150)
  password_hash String         @db.VarChar(255)
  role          String         @default("user") @db.VarChar(10)
  created_at    DateTime       @default(now()) @db.Timestamp(6)
  reservations  reservations[]
  vehicles      vehicles[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model vehicles {
  id            Int            @id @default(autoincrement())
  user_id       Int
  license_plate String         @unique @db.VarChar(20)
  vehicle_type  String         @default("car") @db.VarChar(20)
  created_at    DateTime       @default(now()) @db.Timestamp(6)
  reservations  reservations[]
  users         users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
